<nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 60; display: flex; align-items: center; justify-content: space-between; padding: 18px clamp(20px,5vw,64px); background: rgba(250,248,245,0.5); border-bottom: 1px solid rgba(255,255,255,0.5); backdrop-filter: blur(20px) saturate(120%); -webkit-backdrop-filter: blur(20px) saturate(120%); transition: background .5s ease,border-color .5s ease,box-shadow .5s ease; box-shadow: 0 4px 20px rgba(86,64,110,0.05)">
    <a href="#top" style="display:flex;align-items:center;text-decoration:none"><img src="<%= brand.logo %>" alt="<%= brand.logoAlt %>" style="height:40px;width:auto;filter:brightness(0) contrast(1.1)"></a>
    <button class="nav-burger" data-action="toggleMenu" aria-label="Menu" style="display:none;align-items:center;justify-content:center;width:46px;height:46px;border-radius:14px;border:1px solid rgba(255,255,255,.6);background:rgba(255,255,255,.55);backdrop-filter:blur(14px) saturate(140%);-webkit-backdrop-filter:blur(14px) saturate(140%);cursor:pointer;box-shadow:0 6px 18px rgba(86,64,110,.12);outline:none;padding:0">
      <span data-ref="burger" style="position:relative;display:block;width:20px;height:14px">
        <span style="position:absolute;left:0;top:0;width:100%;height:2px;border-radius:2px;background:#2B2724;transition:transform .35s var(--ease-out),top .35s var(--ease-out),opacity .25s"></span>
        <span style="position:absolute;left:0;top:6px;width:100%;height:2px;border-radius:2px;background:#2B2724;transition:opacity .25s"></span>
        <span style="position:absolute;left:0;top:12px;width:100%;height:2px;border-radius:2px;background:#2B2724;transition:transform .35s var(--ease-out),top .35s var(--ease-out)"></span>
      </span>
    </button>
    <div class="nav-links-desktop" style="display:flex;align-items:center;gap:clamp(22px,3vw,46px)">
      <% nav.links.forEach(function(link) { %>
      <a href="<%= link.href %>" style="font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#4A443F;text-decoration:none;transition:color .4s var(--ease-out)" style-hover="color:#2B2724"><%= link.label %></a>
      <% }); %>
      <a href="#contact" data-action="<%= nav.cta.action %>" style="display:flex;align-items:center;gap:10px;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#2B2724;background:rgba(255,255,255,.55);border:1px solid transparent;background-image:linear-gradient(rgba(255,255,255,.62),rgba(255,255,255,.62)),linear-gradient(98deg,#F2A285,#C2A4D9);background-origin:border-box;background-clip:padding-box,border-box;backdrop-filter:blur(14px) saturate(140%);-webkit-backdrop-filter:blur(14px) saturate(140%);padding:13px 22px;border-radius:999px;text-decoration:none;white-space:nowrap;box-shadow:0 6px 18px rgba(86,64,110,.12);outline:none;transition:transform .4s var(--ease-out),box-shadow .4s var(--ease-out)" style-hover="transform:translateY(-2px);box-shadow:0 10px 26px rgba(234,142,110,.3),0 0 0 1px rgba(255,255,255,.5)" style-active="transform:translateY(0) scale(.97);box-shadow:0 4px 14px rgba(86,64,110,.16)" style-focus="box-shadow:0 0 0 4px rgba(91,200,189,.4),0 8px 22px rgba(86,64,110,.14)"><%= nav.cta.label %><span style="font-size:14px">&rarr;</span></a>
    </div>
  </nav>

  <div class="only-mobile" data-ref="mmenu" style="position:fixed;inset:0;z-index:58;opacity:0;visibility:hidden;transition:opacity .4s var(--ease-out),visibility .4s">
    <div data-action="closeMenu" style="position:absolute;inset:0;background:rgba(43,39,36,.32);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)"></div>
    <div data-ref="mpanel" style="position:absolute;top:0;left:0;right:0;background:rgba(250,248,245,.92);backdrop-filter:blur(28px) saturate(150%);-webkit-backdrop-filter:blur(28px) saturate(150%);border-bottom:1px solid rgba(255,255,255,.7);box-shadow:0 24px 60px rgba(86,64,110,.18);padding:88px clamp(22px,6vw,32px) 30px;transform:translateY(-14px);opacity:0;transition:transform .45s var(--ease-out),opacity .4s var(--ease-out);display:flex;flex-direction:column;gap:6px">
      <% nav.links.forEach(function(link) { %>
      <a href="<%= link.href %>" data-action="closeMenu" style="font-size:15px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#2B2724;text-decoration:none;padding:15px 4px;border-bottom:1px solid rgba(150,141,134,.16)"><%= link.label %></a>
      <% }); %>
      <a href="#contact" data-action="<%= nav.cta.action %>" style="display:flex;align-items:center;justify-content:center;gap:10px;margin-top:18px;font-size:13px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#fff;background:linear-gradient(98deg,#F2A285,#C2A4D9);padding:16px 22px;border-radius:999px;text-decoration:none;box-shadow:0 12px 30px rgba(234,142,110,.32)"><%= nav.cta.label %><span style="font-size:15px">&rarr;</span></a>
    </div>
  </div>
