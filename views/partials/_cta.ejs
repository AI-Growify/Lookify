<section id="contact" class="sec-pad" style="position:relative;padding:clamp(90px,15vh,170px) clamp(20px,5vw,64px);overflow:hidden;background:radial-gradient(60% 80% at 50% 0%,rgba(233,220,242,.7) 0%,transparent 60%),radial-gradient(55% 70% at 50% 100%,rgba(251,227,214,.7) 0%,transparent 62%),#FAF8F5">
    <div style="position:relative;max-width:1000px;margin:0 auto;text-align:center">
      <h2 style="font-weight:800;font-size:clamp(38px,6vw,86px);line-height:1.0;letter-spacing:-.03em;color:#2B2724;max-width:16ch;margin:0 auto;text-wrap:balance">Elevate your <span style="background:linear-gradient(98deg,#EA8E6E,#C2A4D9);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">brand.</span></h2>
      <p style="font-size:clamp(16px,1.3vw,19px);font-weight:500;color:#5E574F;margin:26px auto 0;max-width:54ch;line-height:1.65;text-wrap:pretty">Join the vanguard of luxury commerce. Request a private demonstration of the <%= brand.name %> Virtual Try-On engine.</p>
      <div style="margin-top:38px;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap">
        <a href="#contact" data-action="openModal" style="display:flex;align-items:center;gap:12px;font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#fff;background:linear-gradient(98deg,#F2A285,#C2A4D9);padding:18px 44px;border-radius:999px;text-decoration:none;box-shadow:0 14px 36px rgba(234,142,110,.36);outline:none;transition:transform .4s var(--ease-out),box-shadow .4s var(--ease-out)" style-hover="transform:translateY(-2px);box-shadow:0 20px 48px rgba(234,142,110,.45)" style-active="transform:translateY(0) scale(.97);box-shadow:0 10px 26px rgba(234,142,110,.34)" style-focus="box-shadow:0 0 0 4px rgba(91,200,189,.4),0 14px 36px rgba(234,142,110,.3)"><%= nav.cta.label %><span style="font-size:15px">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- Floating WhatsApp button -->
  <a href="https://wa.me/919810505644?text=Hi!%20I%20came%20across%20your%20Virtual%20Try-On%20app%20through%20the%20Lookify%20landing%20page%20and%20it%20caught%20my%20interest.%0A%0AI%27d%20love%20to%20learn%20more%20about%20how%20it%20works%2C%20its%20features%2C%20pricing%2C%20and%20whether%20it%20can%20be%20customized%20for%20my%20use%20case.%20Could%20you%20share%20some%20details%20or%20schedule%20a%20quick%20demo%3F%0A%0ALooking%20forward%20to%20hearing%20from%20you!" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp" style="position:fixed;bottom:90px;right:28px;z-index:80;width:56px;height:56px;border-radius:50%;background:#25D366;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(37,211,102,.40);transition:transform .3s ease,box-shadow .3s ease" style-hover="transform:translateY(-3px) scale(1.07);box-shadow:0 14px 32px rgba(37,211,102,.50)" style-active="transform:scale(.95)">
    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.55 4.103 1.513 5.834L.057 23.25a.75.75 0 00.918.919l5.498-1.443A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.714 9.714 0 01-4.96-1.358l-.356-.211-3.687.967.985-3.595-.231-.371A9.715 9.715 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
  </a>

  <footer style="border-top:1px solid #EEE9E3;padding:42px clamp(20px,5vw,64px);background:#FAF8F5;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px">
    <a href="#top" style="display:flex;align-items:center;text-decoration:none"><img src="<%= brand.logo %>" alt="<%= brand.logoAlt %>" style="height:36px;width:auto;filter:brightness(0) contrast(1.1)"></a>
    <div style="display:flex;align-items:center;gap:clamp(18px,3vw,30px)">
      <% footer.links.forEach(function(link) { %>
      <a href="<%= link.href || '#' %>"<% if (link.action) { %> data-action="<%= link.action %>"<% } %><% if (link.href && link.href.startsWith('http')) { %> target="_blank" rel="noopener noreferrer"<% } %> style="font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#948D86;text-decoration:none;white-space:nowrap;transition:color .4s var(--ease-out)" style-hover="color:#2B2724"><%= link.label %></a>
      <% }); %>
    </div>
    <div style="font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:#948D86">&copy; <%= brand.year %> <%= brand.name %></div>
  </footer>
